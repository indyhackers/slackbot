{
  "name": "@indyhackers/slackbot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": "11.16.0"
    },
    "runtime": {
      "name": "node",
      "version": "24.18.0"
    }
  },
  "scripts": {
    "start": "node --env-file-if-exists=.env src/index.ts",
    "dev": "node --watch --env-file-if-exists=.env src/index.ts",
    "check-types": "tsc --noEmit",
    "test": "node --test"
  },
  "dependencies": {
    "@slack/bolt": "^4.7.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "typescript": "^7.0.2"
  }
}
